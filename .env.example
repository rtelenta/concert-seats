# ── App Ports ─────────────────────────────────────────────────────────────
CONCERTSEATS_PORT=5000
CATALOG_PORT=5001
SEATING_PORT=5002

# ── Messaging (Redpanda / Kafka) ──────────────────────────────────────────
# From the host (services running on your machine during dev):
KAFKA_BROKERS=localhost:19092
# If running the services INSIDE docker-compose, use: redpanda:9092

# ── OpenTelemetry → Jaeger ─────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Email (Mailpit) ────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025

# ── Clerk ──────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# ── Neon (Postgres serverless) ─────────────────────────────────────────────
# DATABASE-PER-SERVICE: create a separate database per service inside your
# Neon project (or one project per service). No service should know another's
# connection string.
#   sslmode=require is mandatory in Neon.
#   For persistent Nest services use the DIRECT connection string;
#   the 'pooled' (-pooler) one is for serverless/edge environments.
CATALOG_DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/catalog?sslmode=require
SEATING_DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/seating?sslmode=require
BOOKING_DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/booking?sslmode=require
PAYMENT_DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/payment?sslmode=require
READMODEL_DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/read_model?sslmode=require
